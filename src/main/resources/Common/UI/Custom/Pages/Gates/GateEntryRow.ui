@RowTrackButtonStyle = TextButtonStyle(
  Default: (
    Background: (TexturePath: "Images/TrackButtonSecondary.png", Border: 8),
    LabelStyle: (FontSize: 10, TextColor: #bfd7ea, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)
  ),
  Hovered: (
    Background: (TexturePath: "Images/TrackButtonSecondaryHovered.png", Border: 8),
    LabelStyle: (FontSize: 10, TextColor: #e6f4ff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)
  ),
  Pressed: (
    Background: (TexturePath: "Images/TrackButtonSecondaryPressed.png", Border: 8),
    LabelStyle: (FontSize: 10, TextColor: #a8cde7, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)
  )
);

Group {
  LayoutMode: Left;
  Anchor: (Left: 0, Right: 0, Bottom: 6);
  Background: (TexturePath: "Images/ObjectivePanelContainer.png", Border: 15);

  Group #TypeAccent {
    Anchor: (Width: 5);
    Background: #3d7bbf;
  }

  Group {
    FlexWeight: 1;
    LayoutMode: Top;
    Padding: (Left: 12, Right: 8, Top: 10, Bottom: 10);

    Label #Title {
      Text: "-";
      Style: (FontSize: 12, TextColor: #ddeeff, RenderBold: true, VerticalAlignment: Center);
    }

    Group {
      Anchor: (Height: 4);
    }

    Label #Meta {
      Text: "-";
      Style: (FontSize: 10, TextColor: #6e93b0, VerticalAlignment: Center);
    }

    Group {
      Anchor: (Height: 3);
    }

    Label #Status {
      Text: "-";
      Style: (FontSize: 10, TextColor: #82c8e8, VerticalAlignment: Center);
    }
  }

  Group {
    Anchor: (Width: 126);
    LayoutMode: Full;
    Padding: (Left: 10, Right: 10, Top: 10, Bottom: 10);

    TextButton #TrackButton {
      Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
      Text: "TRACK";
      Style: @RowTrackButtonStyle;
    }
  }
}
