Group #EndlessGateTrackerHud {
  LayoutMode: Top;
  Anchor: (Top: 320, Left: 10, Width: 260);

  Group #TrackerPanel {
    LayoutMode: Top;
    Anchor: (Width: 260);
    Padding: (Full: 12);
    Background: (TexturePath: "../Common/ContainerFullPatch.png", Border: 20);

    Label #TrackerHeading {
      Anchor: (Left: 0, Right: 0, Height: 16);
      Style: (
        FontSize: 13,
        TextColor: #f8d66d,
        RenderBold: true,
        HorizontalAlignment: Center,
        VerticalAlignment: Center
      );
      Text: "Tracked Gate";
    }

    Label #TrackerName {
      Anchor: (Top: 4, Left: 0, Right: 0, Height: 18);
      Style: (
        FontSize: 14,
        TextColor: #ffffff,
        RenderBold: true,
        HorizontalAlignment: Center,
        VerticalAlignment: Center,
        Wrap: true
      );
      Text: "--";
    }

    Label #TrackerMeta {
      Anchor: (Top: 4, Left: 0, Right: 0, Height: 16);
      Style: (
        FontSize: 11,
        TextColor: #8fd3ff,
        HorizontalAlignment: Center,
        VerticalAlignment: Center,
        Wrap: true
      );
      Text: "--";
    }

    Label #TrackerGateCoords {
      Anchor: (Top: 6, Left: 0, Right: 0, Height: 16);
      Style: (
        FontSize: 11,
        TextColor: #d9f0ff,
        HorizontalAlignment: Center,
        VerticalAlignment: Center
      );
      Text: "Gate: --";
    }

    Label #TrackerWorld {
      Anchor: (Top: 2, Left: 0, Right: 0, Height: 16);
      Style: (
        FontSize: 11,
        TextColor: #d9f0ff,
        HorizontalAlignment: Center,
        VerticalAlignment: Center
      );
      Text: "World: --";
    }

    Label #TrackerPlayerCoords {
      Anchor: (Top: 2, Left: 0, Right: 0, Height: 16);
      Style: (
        FontSize: 11,
        TextColor: #b9ffd1,
        HorizontalAlignment: Center,
        VerticalAlignment: Center
      );
      Text: "You: --";
    }
  }
}