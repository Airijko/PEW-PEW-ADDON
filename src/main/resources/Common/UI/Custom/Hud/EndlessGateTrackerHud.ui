Group #EndlessGateTrackerHud {
  LayoutMode: Top;
  Anchor: (Top: 92, Right: 12, Width: 320);

  // --- Decorative banner header (gate name) ---
  Group #TrackerBanner {
    Anchor: (Width: 320, Bottom: 6);
    LayoutMode: Top;
    Padding: (Top: 7, Bottom: 7);
    Background: (TexturePath: "Images/ObjectivePanelContainer.png", Border: 15);

    Label #TrackerHeading {
      Anchor: (Left: 0, Right: 0, Bottom: 3);
      Style: (
        FontSize: 11,
        TextColor: #d7e7f7,
        RenderBold: true,
        RenderUppercase: true,
        HorizontalAlignment: Center,
        VerticalAlignment: Center,
        LetterSpacing: 1
      );
      Text: "Tracked Gate";
    }

    Label #TrackerName {
      Anchor: (Left: 0, Right: 0);
      Style: (
        FontSize: 18,
        TextColor: #ffe396,
        RenderBold: true,
        RenderUppercase: true,
        HorizontalAlignment: Center,
        VerticalAlignment: Center
      );
      Text: "--";
    }
  }

  // --- Info panel below banner ---
  Group #TrackerPanel {
    LayoutMode: Top;
    Anchor: (Width: 320);
    Padding: (Horizontal: 16, Top: 9, Bottom: 10);
    Background: (TexturePath: "Images/ObjectivePanelContainer.png", Border: 15);

    // Type | Rank | Status row with icon
    Group {
      LayoutMode: Left;
      Anchor: (Bottom: 6);

      Group #TrackerTypeIcon {
        Anchor: (Width: 14, Height: 14, Top: 2);
        Background: "Images/ObjectiveTaskIconDefault.png";
      }

      Label #TrackerMeta {
        Anchor: (Left: 6);
        Style: (
          FontSize: 13,
          TextColor: #a8dcff,
          RenderBold: true,
          VerticalAlignment: Center
        );
        Text: "--";
      }
    }

    Group {
      Anchor: (Height: 1, Bottom: 7);
      Background: #ffffff(0.16);
    }

    Label #TrackerGateCoords {
      Anchor: (Bottom: 3);
      Style: (FontSize: 13, TextColor: #ecf7ff, RenderBold: true, VerticalAlignment: Center);
      Text: "Gate: --";
    }

    Label #TrackerWorld {
      Anchor: (Bottom: 3);
      Style: (FontSize: 13, TextColor: #ecf7ff, RenderBold: true, VerticalAlignment: Center);
      Text: "World: --";
    }

    Label #TrackerPlayerCoords {
      Style: (FontSize: 13, TextColor: #d2ffdf, RenderBold: true, VerticalAlignment: Center);
      Text: "You: --";
    }
  }
}
